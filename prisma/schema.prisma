generator client {
  provider = "prisma-client-js"
  output   = "../apps/server/src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id           String       @id
  scope_path   String       @unique
  git_root     String?      @unique
  remote_url   String?      @unique
  repo_name    String?
  display_name String?
  created_at   String
  updated_at   String

  nodes MemoryNode[]

  @@map("projects")
}

model MemoryNode {
  id            String  @id
  project_id    String
  parent_id     String?
  level         String
  memory_type   String
  title         String
  summary       String?
  content       String?
  status        String  @default("active")
  importance    Float   @default(0.5)
  source        String?
  metadata_json String?
  created_at    String
  updated_at    String

  project               Project         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  parent                MemoryNode?     @relation("NodeParent", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children              MemoryNode[]    @relation("NodeParent")
  closure_as_ancestor   MemoryClosure[] @relation("ClosureAncestor")
  closure_as_descendant MemoryClosure[] @relation("ClosureDescendant")
  edges_from            MemoryEdge[]    @relation("EdgeFrom")
  edges_to              MemoryEdge[]    @relation("EdgeTo")

  @@index([project_id])
  @@index([parent_id])
  @@index([memory_type])
  @@index([level])
  @@index([status])
  @@map("memory_nodes")
}

model MemoryClosure {
  ancestor_id   String
  descendant_id String
  depth         Int

  ancestor   MemoryNode @relation("ClosureAncestor", fields: [ancestor_id], references: [id], onDelete: Cascade)
  descendant MemoryNode @relation("ClosureDescendant", fields: [descendant_id], references: [id], onDelete: Cascade)

  @@id([ancestor_id, descendant_id])
  @@index([descendant_id])
  @@map("memory_closure")
}

model MemoryEdge {
  from_id       String
  to_id         String
  relation      String
  metadata_json String?

  from MemoryNode @relation("EdgeFrom", fields: [from_id], references: [id], onDelete: Cascade)
  to   MemoryNode @relation("EdgeTo", fields: [to_id], references: [id], onDelete: Cascade)

  @@id([from_id, to_id, relation])
  @@map("memory_edges")
}
