{
  "name": "memory-mcp-lite",
  "version": "0.1.0",
  "private": true,
  "description": "A lightweight, structured, token-efficient local-first MCP memory server",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && node esbuild.config.mjs",
    "dev": "tsx watch apps/server/src/index.ts",
    "start": "node dist/index",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "better-sqlite3": "^11.9.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.1",
    "esbuild": "0.28.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "prisma": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
