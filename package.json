{
  "name": "memory-mcp-lite",
  "version": "2.0.0",
  "description": "A lightweight, structured, token-efficient local-first MCP memory server (Drizzle + libSQL)",
  "bin": {
    "memory-mcp-lite": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && node esbuild.config.mjs",
    "dev": "tsx watch apps/server/src/index.ts",
    "start": "node dist/index",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.36.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "drizzle-kit": "^0.28.0",
    "esbuild": "0.28.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "mcpName": "io.github.thuupx/memory-mcp-lite"
}
